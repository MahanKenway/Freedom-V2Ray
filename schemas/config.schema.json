{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Freedom-V2Ray Normalized Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "server", "port", "metadata"],
  "properties": {
    "protocol": {
      "type": "string",
      "enum": ["vless", "vmess", "trojan", "ss", "mix"]
    },
    "server": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "uuid": {"type": ["string", "null"]},
    "password": {"type": ["string", "null"]},
    "method": {"type": ["string", "null"]},
    "network": {"type": ["string", "null"]},
    "security": {"type": ["string", "null"]},
    "name": {"type": ["string", "null"]},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "raw_hash", "fetched_at", "validation_status"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "raw_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "fetched_at": {"type": "string", "format": "date-time"},
        "checked_at": {"type": ["string", "null"], "format": "date-time"},
        "latency_ms": {"type": ["integer", "null"], "minimum": 0},
        "validation_status": {
          "type": "string",
          "enum": ["valid", "invalid", "timeout", "unreachable", "rate_limited", "not_tested"]
        }
      }
    }
  }
}
